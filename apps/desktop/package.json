{
  "name": "@tabghost/desktop",
  "version": "0.2.1",
  "description": "TabGhost launcher: automation API server + CLI over session-core.",
  "type": "module",
  "bin": {
    "tabghost": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/server.ts",
    "start:node": "tsx src/main.ts serve",
    "dev": "bun --watch run src/server.ts",
    "dev:node": "tsx --watch src/main.ts serve",
    "cli": "bun run src/cli.ts",
    "cli:node": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@tabghost/session-core": "workspace:*",
    "hono": "^4.6.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
