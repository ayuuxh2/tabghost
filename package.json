{
  "name": "tabghost",
  "private": true,
  "version": "0.2.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --cwd packages/session-core test",
    "api": "bun run --cwd apps/desktop start",
    "api:node": "tsx apps/desktop/src/main.ts serve",
    "dev": "bun run --cwd apps/desktop dev",
    "dev:node": "tsx --watch apps/desktop/src/main.ts serve",
    "cli": "bun run --cwd apps/desktop cli",
    "cli:node": "tsx apps/desktop/src/main.ts",
    "web": "bun run --cwd apps/control-panel dev",
    "build:core": "bun run --cwd packages/session-core build"
  },
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
